      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"cabId\": 101,\n    \"driverName\": \"Arjun\",\n    \"x\": 5,\n    \"y\": 7\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/cabs/add",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "cabs", "add"]
        }
      }
    },
